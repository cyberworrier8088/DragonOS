limine-bin/

# Game data files (obtain separately; see README)
pak0.pak
*.wad

# Temporary diagnostic files
tools_tmp/

# Persistent disk image backing /dev/sda (generated by `make run`; holds
# whatever the guest has written across sessions, so it's local state, not
# source -- see the disk.img rule in the Makefile)
disk.img

# Persistent disk image backing /dev/nvme0n1 (generated by `make run`; same
# reasoning as disk.img above -- see the nvme_disk.img rule in the Makefile)
nvme_disk.img

